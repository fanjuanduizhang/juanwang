# SurveyKing .gitignore

# === 编译输出 ===
build/
bin/main/
*.jar
*.war
*.class

# === Gradle ===
.gradle/

# === IDE ===
.idea/
*.iml
*.iws
*.ipr
.vscode/

# === 日志和临时文件 ===
logs/
*.log

